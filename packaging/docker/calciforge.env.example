# Copy to .env or pass with docker compose --env-file.
#
# CALCIFORGE_IMAGE can point at a published image once release images exist.
# When running from the repository, docker compose can build the image locally.
CALCIFORGE_IMAGE=calciforge:local
CALCIFORGE_CONFIG=./config.example.toml
CALCIFORGE_AGENTS_CONFIG=./agents.example.json
CALCIFORGE_CLASHD_POLICY=./policy.example.star
CALCIFORGE_DATA=./data
CALCIFORGE_PROXY_PORT=18792
CALCIFORGE_SECURITY_PROXY_PORT=8888
CALCIFORGE_CLASHD_PORT=9001
RUST_LOG=calciforge=info,security_proxy=info,clashd=info
