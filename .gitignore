# Local operator notes and deployment inventory.
# These can include private hostnames, LAN addresses, and session handoff notes.
research/
scripts/targets.txt
deploy/nodes.json
deploy/*.local.json

# ── secrets / credentials — never commit ────────────────────────────────────
# Defense in depth; main guard is .gitleaks.toml + CI. These keep obvious
# secret-file shapes out of accidental adds.
.env
.env.*
!.env.example
!.env.*.example
*.secret
*.secret.*
secrets/
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
*.pem
*.key
!tests/**/*.pem
!tests/**/*.key

# Per-deployment gitleaks rules (holds personal infra patterns)
# — see .gitleaks.local.toml.example for the template
.gitleaks.local.toml
homeserver.log
.claude/REVIEW_PENDING
.claude/pending-reviews/
.claude/settings.local.json
.claude/.last-reviewed-sha
fnox.toml
.claude/worktrees/
