{
  "nodes": [
    {
      "name": "linux-gateway",
      "host": "gateway.example.internal",
      "user": "root",
      "ssh_key": "~/.ssh/id_ed25519",
      "arch": "x86_64-unknown-linux-musl",
      "os": "linux",
      "services": ["clashd", "security-proxy"],
      "install_dir": "/usr/local/bin",
      "config_dir": "/etc/calciforge"
    },
    {
      "name": "linux-worker",
      "host": "worker.example.internal",
      "user": "root",
      "ssh_key": "~/.ssh/id_ed25519",
      "arch": "x86_64-unknown-linux-musl",
      "os": "linux",
      "services": ["clashd", "security-proxy", "calciforge"],
      "install_dir": "/usr/local/bin",
      "config_dir": "/etc/calciforge"
    },
    {
      "name": "mac-satellite",
      "host": "mac.example.internal",
      "user": "operator",
      "ssh_key": "~/.ssh/id_ed25519",
      "arch": "aarch64-apple-darwin",
      "os": "macos",
      "services": ["clashd", "security-proxy"],
      "install_dir": "/usr/local/bin",
      "config_dir": "/Users/admin/.clash"
    }
  ]
}
